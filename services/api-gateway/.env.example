NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
COOKIE_NAME=ecobazar_session
JWT_PUBLIC_KEY_PATH=../../.secrets/jwt-public.pem
# Para desarrollo fuera de Docker también puede usarse un PEM con saltos escapados:
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_ISSUER=ecobazar-identity
JWT_AUDIENCE=ecobazar-api
IDENTITY_SERVICE_URL=http://localhost:4001
CATALOG_SERVICE_URL=http://localhost:4002
CART_SERVICE_URL=http://localhost:4003
ORDER_SERVICE_URL=http://localhost:4004
PAYMENT_SERVICE_URL=http://localhost:4005
MODERATION_SERVICE_URL=http://localhost:4006
INTERNAL_SERVICE_TOKEN=change_this_internal_token_32_chars
SESSION_TIMEOUT_MS=2000
PROXY_TIMEOUT_MS=10000
HEALTH_TIMEOUT_MS=2000
