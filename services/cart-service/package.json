    "test": "npm run check && node --test test/*.test.js"
  },
  "dependencies": {
    "@ecobazar/contracts": "^1.0.0",
    "@ecobazar/platform": "^1.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
