NODE_ENV=development
PORT=4001
DATABASE_URL=postgres://ecobazar_identity:identity_dev@localhost:5432/bd_EcoBazar
RABBITMQ_URL=amqp://ecobazar:ecobazar_dev@localhost:5672
JWT_PRIVATE_KEY_PATH=../../.secrets/jwt-private.pem
# Para desarrollo fuera de Docker también puede usarse un PEM con saltos escapados:
# JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
JWT_EXPIRES_IN=7d
JWT_ISSUER=ecobazar-identity
JWT_AUDIENCE=ecobazar-api
COOKIE_NAME=ecobazar_session
GOOGLE_CLIENT_ID=
# Tokens diferentes, separados por coma, para servicios autorizados.
INTERNAL_SERVICE_TOKENS=change_this_internal_token_32_chars
# Compatibilidad local si sólo se configura un consumidor:
# INTERNAL_SERVICE_TOKEN=change_this_internal_token_32_chars
OUTBOX_INTERVAL_MS=1000
