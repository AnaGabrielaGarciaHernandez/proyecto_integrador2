{
  "name": "@ecobazar/identity-service",
  "version": "1.0.0",
  "private": true,
  "description": "EcoBazar identity and authentication microservice",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "node src/migrate.js",
    "check": "find src test -name '*.js' -exec node --check {} \\;",
    "test": "npm run check && node --test test/*.test.js"
  },
  "dependencies": {
    "@ecobazar/contracts": "*",
    "@ecobazar/platform": "*",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.9.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
